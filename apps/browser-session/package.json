{
  "name": "@job-boardwalk/browser-session",
  "private": true,
  "description": "Persistent MCP gateway to a user-visible Playwright browser on a graphical host.",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "vite build",
    "dev": "tsx watch src/browser-session-server.ts",
    "lint": "oxlint --config oxlint.config.ts .",
    "mcp": "tsx src/browser-session-server.ts",
    "start": "node dist/browser-session-server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p test/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@job-boardwalk/contracts": "workspace:*",
    "@job-boardwalk/platform-catalog": "workspace:*",
    "@modelcontextprotocol/sdk": "catalog:",
    "@shajara/host": "catalog:"
  },
  "devDependencies": {
    "@job-boardwalk/presets": "workspace:*",
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "tsx": "^4.20.3",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
