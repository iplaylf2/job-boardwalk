{
  "name": "@job-boardwalk/browser-session",
  "private": true,
  "description": "Visible persistent Playwright browser shared by the user and agent through MCP.",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "tsx watch src/browser-session-server.ts",
    "lint": "oxlint --config oxlint.config.ts .",
    "start": "node dist/browser-session-server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@job-boardwalk/contracts": "workspace:*",
    "@job-boardwalk/platform-catalog": "workspace:*",
    "@job-boardwalk/storage-layout": "workspace:*",
    "@modelcontextprotocol/sdk": "catalog:",
    "@playwright/mcp": "catalog:",
    "@shajara/host": "catalog:",
    "playwright": "catalog:"
  },
  "devDependencies": {
    "@job-boardwalk/presets": "workspace:*",
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "tsx": "^4.20.3",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
