{
  "name": "@job-boardwalk/browser-session",
  "private": true,
  "description": "Persistent HTTP MCP gateway to a user-owned browser over Patchright CDP.",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "vite build",
    "dev": "tsx watch src/main.ts",
    "lint": "oxlint --config oxlint.config.ts .",
    "start": "node dist/browser-session.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p test/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@job-boardwalk/platform-catalog": "workspace:*",
    "@modelcontextprotocol/sdk": "catalog:",
    "@shajara/host": "catalog:",
    "hono": "catalog:",
    "patchright": "1.61.1",
    "proxy-from-env": "2.1.0"
  },
  "devDependencies": {
    "@job-boardwalk/presets": "workspace:*",
    "@types/node": "catalog:",
    "@types/proxy-from-env": "1.0.4",
    "oxlint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
