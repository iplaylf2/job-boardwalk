{
  "name": "@job-boardwalk/runtime",
  "private": true,
  "description": "Local collaboration runtime for MCP, browser handoff, and workspace state.",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "vite build",
    "dev": "tsx watch src/runtime-server.ts",
    "db:generate": "drizzle-kit generate",
    "mcp": "tsx src/mcp-server.ts",
    "lint": "oxlint --config oxlint.config.ts .",
    "start": "node dist/runtime-server.js",
    "start:mcp": "node dist/mcp-server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p test/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "2.0.8",
    "@job-boardwalk/contracts": "workspace:*",
    "@job-boardwalk/platform-catalog": "workspace:*",
    "@job-boardwalk/storage-layout": "workspace:*",
    "@modelcontextprotocol/sdk": "catalog:",
    "@shajara/host": "catalog:",
    "arktype": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "4.12.29",
    "playwright": "catalog:"
  },
  "devDependencies": {
    "@job-boardwalk/presets": "workspace:*",
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "oxlint": "catalog:",
    "tsx": "^4.20.3",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
