{
  "name": "@job-boardwalk/state-service",
  "private": true,
  "description": "Local persistence and semantic state API for Job Boardwalk.",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "vite build",
    "dev": "tsx watch src/main.ts",
    "lint": "oxlint --config oxlint.config.ts .",
    "start": "node dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p test/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "2.0.8",
    "@job-boardwalk/platforms": "workspace:*",
    "@job-boardwalk/state-api": "workspace:*",
    "@job-boardwalk/storage-layout": "workspace:*",
    "@shajara/host": "catalog:",
    "hono": "4.12.29"
  },
  "devDependencies": {
    "@job-boardwalk/presets": "workspace:*",
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "tsx": "^4.20.3",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
