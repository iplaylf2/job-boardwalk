{
  "extends": "dependency-cruiser/configs/recommended-strict",
  "forbidden": [
    {
      "name": "no-orphans",
      "severity": "ignore",
      "from": {},
      "to": {}
    }
  ],
  "options": {
    "exclude": {
      "path": "(^|/)dist($|/)"
    },
    "enhancedResolveOptions": {
      "conditionNames": ["import", "require", "node", "default"],
      "exportsFields": ["exports"]
    }
  }
}
