# Required by Browser Session. When Playwright MCP runs across a VM, WSL, or container boundary,
# replace 127.0.0.1 with an address that is reachable from the agent environment.
JOB_BOARDWALK_PLAYWRIGHT_MCP_URL=http://127.0.0.1:8931/mcp

# Optional. Workspace Service uses this loopback URL by default.
# JOB_BOARDWALK_WORKSPACE_SERVICE_URL=http://127.0.0.1:54310

# Optional. Prefer an absolute path when relocating local state.
# JOB_BOARDWALK_HOME=/path/to/job-boardwalk-state
