# Optional Browser Session profile path. Defaults to the operating system's user data directory.
# JOB_BOARDWALK_BROWSER_PROFILE_PATH=/path/to/browser-profile

# Optional Workspace Service database path. Defaults to the operating system's user data directory.
# JOB_BOARDWALK_WORKSPACE_DATABASE_PATH=/path/to/workspace.sqlite

# Optional Workspace Service base URL for Browser Session status reports.
# JOB_BOARDWALK_WORKSPACE_SERVICE_URL=http://127.0.0.1:54310
