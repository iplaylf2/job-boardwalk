# Required by Browser Session. The graphical host must run Edge or Chrome with a dedicated
# user-data-dir and expose this CDP HTTP endpoint to the project environment.
JOB_BOARDWALK_CDP_URL=http://172.19.0.1:9222

# Optional override. When omitted, Browser Session follows HTTP_PROXY/NO_PROXY via proxy-from-env.
# Set an empty value to require a direct connection. The proxy must support HTTP CONNECT.
# JOB_BOARDWALK_CDP_PROXY_URL=http://172.19.0.1:7897

# Optional. Prefer an absolute path when relocating local state.
# JOB_BOARDWALK_HOME=/path/to/job-boardwalk-state
